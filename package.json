{
	"name": "@neovici/cosmoz-tabs",
	"version": "10.0.0-beta.2",
	"description": "A multi views container element that allows navigation between the views using tabs.",
	"keywords": [
		"web-components",
		"pion",
		"lit-html",
		"tabs",
		"design-system",
		"untitled-ui"
	],
	"homepage": "https://github.com/Neovici/cosmoz-tabs#readme",
	"bugs": {
		"url": "https://github.com/Neovici/cosmoz-tabs/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neovici/cosmoz-tabs.git"
	},
	"license": "Apache-2.0",
	"author": "Neovici Development <dev@neovici.se>",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist/",
		"custom-elements.json"
	],
	"scripts": {
		"lint": "tsc && eslint --cache .",
		"check:duplicates": "check-duplicate-components",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"test:storybook": "vitest --project=storybook --run",
		"test:watch": "vitest",
		"storybook:start": "storybook dev -p 8000",
		"storybook:build": "storybook build",
		"storybook:preview": "npm run storybook:build && http-server ./storybook-static/ --silent",
		"changeset": "changeset",
		"prepare": "husky"
	},
	"publishConfig": {
		"access": "public"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		],
		"rules": {
			"body-max-line-length": [
				1,
				"always",
				600
			]
		}
	},
	"exports": {
		".": "./dist/index.js",
		"./cosmoz-tabs": "./dist/cosmoz-tabs.js",
		"./cosmoz-tab": "./dist/cosmoz-tab.js",
		"./cosmoz-tab-card": "./dist/cosmoz-tab-card.js",
		"./cosmoz-tab-card.js": "./dist/cosmoz-tab-card.js",
		"./styles": "./dist/styles.js",
		"./next": "./dist/next/index.js",
		"./next/*": "./dist/next/*"
	},
	"dependencies": {
		"@neovici/cosmoz-collapse": "^1.6.0",
		"@neovici/cosmoz-router": "^11.3.0",
		"@neovici/cosmoz-tokens": "^3.4.0",
		"@neovici/cosmoz-utils": "^6.22.0",
		"@pionjs/pion": "^2.16.0",
		"compute-scroll-into-view": "^3.1.1",
		"lit-html": "^3.3.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@neovici/cfg": "^2.13.0",
		"@neovici/cosmoz-icons": "^1.6.0",
		"@neovici/testing": "^2.3.0",
		"@playwright/test": "^1.61.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/web-components": "^10.4.6",
		"@storybook/web-components-vite": "^10.4.6",
		"@types/node": "^25.9.3",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"http-server": "^14.1.1",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"shadow-dom-testing-library": "^1.14.0",
		"sinon": "^22.0.0",
		"storybook": "^10.4.6",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	}
}
